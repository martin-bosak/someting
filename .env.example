# HOSTING_ROOT is the path inside the control-plane container; HOSTING_ROOT_HOST
# is the same tree on the Docker host. They MUST be identical absolute paths in
# production: site containers bind-mount persistent storage (sites/<slug>/shared
# -> /data) and those mounts are resolved by the host Docker daemon. If the two
# differ, the daemon mounts a path that does not exist and site storage breaks.
HOSTING_ROOT=/srv/hosting
HOSTING_ROOT_HOST=/srv/hosting
MANAGEMENT_HOST=admin.example.com
# Production: use your admin hostname exactly (e.g. someting.somesoft.net) - never http:// , no trailing :443.
# Caddy requests Let's Encrypt certs for MANAGEMENT_HOST and for every hostname after you click Apply route.

POSTGRES_DB=someting
POSTGRES_USER=someting
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://someting:change-me@postgres:5432/someting

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now
SESSION_SECRET=change-me-to-a-random-32-byte-string

PORT=3000
CREATE_SITE_SCRIPT=/srv/hosting/bin/create-site.sh
DEPLOY_SCRIPT=/srv/hosting/bin/deploy-site.sh
BACKUP_DIR=/srv/hosting/backups

# Optional: used by deploy/vps-deploy.ps1 and VS Code task "Deploy control plane to VPS"
# SOMETING_VPS_HOST=95.217.223.133
# SOMETING_VPS_USER=root
# SOMETING_SSH_KEY=%USERPROFILE%\.ssh\your_key
# SOMETING_REMOTE_DIR=/opt/someting
# Extra paths comma-separated if install is elsewhere: SOMETING_REMOTE_DIR_CANDIDATES=/root/someting,/srv/hosting/stack
# SOMETING_SKIP_GIT_PULL=1 matches vps-deploy.ps1 -SkipGitPull (compose only)
# Control-plane folder on VPS for tarball deploy: SOMETING_SYNC_REMOTE_DIR=/opt/someting
